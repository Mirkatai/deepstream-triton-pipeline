# Triton model config for frame_analyzer
# Python backend — Triton 25.03 / DeepStream 8.0 compatible
# Blackwell GPU supported via CUDA 12.8 + TensorRT 10.9

name: "frame_analyzer"
backend: "python"
max_batch_size: 0          # disabled — sequence batcher controls batching

# Two instances per GPU for parallel stream inference
# Increase count for more simultaneous streams
instance_group [
  {
    count: 2
    kind: KIND_GPU
    gpus: [ 0 ]
  }
]

input [
  {
    name: "input_frame"
    data_type: TYPE_UINT8
    dims: [ -1, -1, 3 ]    # H x W x C (dynamic shape)
  }
]

output [
  {
    name: "overlay_data"
    data_type: TYPE_FP32
    dims: [ -1, 6 ]        # N detections x [x1, y1, x2, y2, class_id, conf]
  }
]

# Sequence Batcher — guarantees per-stream frame ORDER
# sequence_id maps 1:1 to stream_id in the pipeline (stream_id + 1)
sequence_batching {
  max_sequence_idle_microseconds: 5000000
  control_input [
    {
      name: "START"
      control [
        {
          kind: CONTROL_SEQUENCE_START
          int32_false_true: [ 0, 1 ]
        }
      ]
    },
    {
      name: "END"
      control [
        {
          kind: CONTROL_SEQUENCE_END
          int32_false_true: [ 0, 1 ]
        }
      ]
    },
    {
      name: "READY"
      control [
        {
          kind: CONTROL_SEQUENCE_READY
          int32_false_true: [ 0, 1 ]
        }
      ]
    },
    {
      name: "CORRID"
      control [
        {
          kind: CONTROL_SEQUENCE_CORRID
          data_type: TYPE_UINT64
        }
      ]
    }
  ]
  oldest {
    max_candidate_sequences: 32
    preferred_batch_size: [ 1, 2, 4 ]
    max_queue_delay_microseconds: 5000
  }
}

# Warmup — eliminates cold-start latency on first real frame
model_warmup [
  {
    name: "warmup_batch"
    batch_size: 1
    inputs {
      key: "input_frame"
      value {
        data_type: TYPE_UINT8
        dims: [ 720, 1280, 3 ]
        zero_data: true
      }
    }
  }
]
